# ---- Telegram ----
# 1) Create a bot: message @BotFather on Telegram -> /newbot -> copy the token.
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2) Get your chat id: message @userinfobot (it replies with your numeric id),
#    OR after sending your bot a message, open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  and read "chat":{"id":...}
TELEGRAM_CHAT_ID=987654321

# ---- What to watch ----
# EASIEST: just list the cities you want, comma-separated. Each is geocoded to
# a map area automatically. Leave SEARCH_URLS empty if you use this.
CITIES=Lyon, Toulouse, Rennes
# The campaign number in /tools/<N>/search — CHANGES EACH ACADEMIC YEAR.
# Open trouverunlogement.lescrous.fr, start any search, and read the number
# in the URL. Required when using CITIES.
TOOL_ID=42

# ADVANCED (optional): exact search URLs copied from the site AFTER drawing your
# zone / picking filters (room type, price, etc.). Separate several with "|".
# These are combined with CITIES above. Leave blank if you only use CITIES.
SEARCH_URLS=

# ---- Behaviour (optional; sane defaults) ----
POLL_INTERVAL=300          # seconds between checks (300 = 5 min). Be polite.
JITTER=60                  # random extra 0..N seconds so polls aren't robotic
PAGE_DELAY=1.5             # delay between paginated requests
MAX_PAGES=20               # safety cap
STATE_FILE=seen.json       # remembers what you've already been alerted about
NOTIFY_ON_FIRST_RUN=false  # true = also alert on everything already online now
NOTIFY_REMOVED=true        # also ping when an offer disappears from a city
